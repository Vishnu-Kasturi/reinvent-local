{
    "run_type": "staged_learning",
    "device": "cpu",
    "use_cuda": true,
    "tb_logdir": "../tb_jak2_rl",
    "json_out_config": "json_jak2_rl_v2.json",
    "seed": null,
    "parameters": {
        "prior_file": "priors/reinvent.prior",
        "agent_file": "../models/jak2_focused.model",
        "summary_csv_prefix": "../results/focused_rl_v2",
        "use_checkpoint": false,
        "purge_memories": true,
        "smiles_file": null,
        "sample_strategy": "multinomial",
        "distance_threshold": 99999,
        "batch_size": 64,
        "randomize_smiles": true,
        "unique_sequences": true,
        "temperature": 1.0,
        "tb_isim": false
    },
    "scoring": null,
    "scheduler": null,
    "responder": null,
    "filter": null,
    "stage": [
        {
            "max_steps": 300,
            "max_score": 1.0,
            "chkpt_file": "../models/jak2_rl_stage1_v2.chkpt",
            "termination": "simple",
            "min_steps": 50,
            "scoring": {
                "type": "geometric_mean",
                "component": [
                    {
                        "QED": {
                            "endpoint": [
                                {
                                    "name": "QED",
                                    "weight": 1.0
                                }
                            ]
                        }
                    },
                    {
                        "MolecularWeight": {
                            "endpoint": [
                                {
                                    "name": "MolecularWeight",
                                    "weight": 1.0,
                                    "transform": {
                                        "type": "double_sigmoid",
                                        "low": 300.0,
                                        "high": 550.0,
                                        "coef_div": 500.0,
                                        "coef_si": 20.0,
                                        "coef_se": 20.0
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "JAK2pIC50": {
                            "endpoint": [
                                {
                                    "name": "JAK2pIC50",
                                    "weight": 2.0,
                                    "params": {
                                        "model_path": "../data/xgb_model.ubj",
                                        "scaler_path": "../data/desc_scaler.pkl"
                                    }
                                },
                                {
                                    "name": "JAK2pIC50_raw",
                                    "weight": 0.0,
                                    "params": {
                                        "model_path": "../data/xgb_model.ubj",
                                        "scaler_path": "../data/desc_scaler.pkl"
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "TanimotoPenalty": {
                            "endpoint": [
                                {
                                    "name": "TanimotoPenalty",
                                    "weight": 1.0,
                                    "params": {
                                        "smiles_file": "../data/custom_train.smi",
                                        "threshold": 0.5,
                                        "radius": 2
                                    }
                                },
                                {
                                    "name": "MaxTanimoto",
                                    "weight": 0.0,
                                    "params": {
                                        "smiles_file": "../data/custom_train.smi",
                                        "threshold": 0.5,
                                        "radius": 2
                                    }
                                }
                            ]
                        }
                    }
                ],
                "filename": null
            },
            "diversity_filter": null
        },
        {
            "max_steps": 500,
            "max_score": 1.0,
            "chkpt_file": "../models/jak2_rl_stage2_v2.chkpt",
            "termination": "simple",
            "min_steps": 50,
            "scoring": {
                "type": "geometric_mean",
                "component": [
                    {
                        "QED": {
                            "endpoint": [
                                {
                                    "name": "QED",
                                    "weight": 1.0
                                }
                            ]
                        }
                    },
                    {
                        "MolecularWeight": {
                            "endpoint": [
                                {
                                    "name": "MolecularWeight",
                                    "weight": 1.0,
                                    "transform": {
                                        "type": "double_sigmoid",
                                        "low": 300.0,
                                        "high": 550.0,
                                        "coef_div": 500.0,
                                        "coef_si": 20.0,
                                        "coef_se": 20.0
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "JAK2pIC50": {
                            "endpoint": [
                                {
                                    "name": "JAK2pIC50",
                                    "weight": 2.0,
                                    "params": {
                                        "model_path": "../data/xgb_model.ubj",
                                        "scaler_path": "../data/desc_scaler.pkl"
                                    }
                                },
                                {
                                    "name": "JAK2pIC50_raw",
                                    "weight": 0.0,
                                    "params": {
                                        "model_path": "../data/xgb_model.ubj",
                                        "scaler_path": "../data/desc_scaler.pkl"
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "TanimotoPenalty": {
                            "endpoint": [
                                {
                                    "name": "TanimotoPenalty",
                                    "weight": 1.0,
                                    "params": {
                                        "smiles_file": "../data/custom_train.smi",
                                        "threshold": 0.5,
                                        "radius": 2
                                    }
                                },
                                {
                                    "name": "MaxTanimoto",
                                    "weight": 0.0,
                                    "params": {
                                        "smiles_file": "../data/custom_train.smi",
                                        "threshold": 0.5,
                                        "radius": 2
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "NumRotBond": {
                            "endpoint": [
                                {
                                    "name": "NumRotBond",
                                    "weight": 1.0,
                                    "transform": {
                                        "type": "reverse_sigmoid",
                                        "high": 10.0,
                                        "low": 2.0,
                                        "k": 20.0
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "TPSA": {
                            "endpoint": [
                                {
                                    "name": "TPSA",
                                    "weight": 1.0,
                                    "transform": {
                                        "type": "double_sigmoid",
                                        "low": 50.0,
                                        "high": 130.0,
                                        "coef_div": 150.0,
                                        "coef_si": 20.0,
                                        "coef_se": 20.0
                                    }
                                }
                            ]
                        }
                    }
                ],
                "filename": null
            },
            "diversity_filter": null
        }
    ],
    "learning_strategy": {
        "type": "dap",
        "sigma": 128,
        "rate": 0.0001
    },
    "diversity_filter": {
        "type": "IdenticalMurckoScaffold",
        "bucket_size": 8,
        "minscore": 0.35,
        "minsimilarity": 0.4,
        "penalty_multiplier": 0.5
    },
    "intrinsic_penalty": null,
    "inception": {
        "smiles_file": "../data/custom_train.smi",
        "memory_size": 200,
        "sample_size": 20,
        "deduplicate": true
    }
}